# Copy this file to .env and fill in your values.
# Register an app at https://portal.azure.com -> Azure Active Directory -> App registrations

# The Application (client) ID from your Azure app registration
CLIENT_ID=your-client-id-here

# Your RPI tenant ID (or "common" if using a personal Microsoft account)
# For RPI, find this at: https://login.microsoftonline.com/rpi.edu/.well-known/openid-configuration
TENANT_ID=rpi.edu

# Your RPI email address (the "from" address)
SENDER_EMAIL=kollah@rpi.edu
