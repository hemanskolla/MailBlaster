# Copy this file to .env and fill in your values.

# Your Gmail address
GMAIL_ADDRESS=hemanskolla@gmail.com

# Display name shown to recipients in their inbox (optional)
SENDER_NAME=Innovation Weekend Message

# A Gmail App Password (NOT your regular Gmail password).
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on your Google account)
GMAIL_APP_PASSWORD=your-16-character-app-password-here
